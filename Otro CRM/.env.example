# =============================================
# WHATSAPP CLOUD API (Meta Business)
# =============================================
# Token permanente de tu app en Meta Business
WHATSAPP_TOKEN=tu_token_aqui
# ID del número de teléfono de WhatsApp Business
WHATSAPP_PHONE_ID=tu_phone_id_aqui
# Token de verificación del webhook (invéntalo tú)
WHATSAPP_VERIFY_TOKEN=tu_token_verificacion_secreto

# =============================================
# GEMINI API (Google AI)
# =============================================
GEMINI_API_KEY=tu_api_key_gemini_aqui

# =============================================
# NTFY.SH (Alertas urgentes)
# =============================================
# Nombre de tu canal privado (ej: investigalo-urgencias-abc123)
NTFY_TOPIC=investigalo-urgencias-tu_codigo_secreto

# =============================================
# CONFIGURACIÓN GENERAL
# =============================================
PORT=3000
# Zona horaria (Europe/Madrid para España peninsular)
TZ=Europe/Madrid
# Teléfono del detective para incluir en alertas
DETECTIVE_PHONE=+34600000000
